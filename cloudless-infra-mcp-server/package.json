{
  "name": "cloudless-infra-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for cloudless.gr infrastructure — Pi cluster (K3s, Home Assistant, failover) + AWS (Lambda, Route 53, SSM)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.600.0",
    "@aws-sdk/client-route-53": "^3.600.0",
    "@aws-sdk/client-ssm": "^3.600.0",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "node-ssh": "^13.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["cpu-features", "ssh2", "esbuild"]
  }
}
